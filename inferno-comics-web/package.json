{
  "name": "inferno-comics-web",
  "version": "0.7.23",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --host 0.0.0.0 --port=4300",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "name": "echo ${npm_package_name}",
    "test": "ng test",
    "lint": "ng lint",
    "gen-version": "node scripts/gen-version.js",
    "build:app": "NODE_OPTIONS=--max_old_space_size=8192 pnpm build --configuration=production",
    "build:prod": "pnpm build --configuration production",
    "docker:build": "npm run gen-version && npm run docker:build-compile -s && npm run docker:build-runtime -s && npm run docker:push -s",
    "docker:build-compile": "export PROJECT=$(jq -r .name package.json) && docker buildx build --target compile-stage --build-arg BUILDKIT_INLINE_CACHE=1 -t infernokun/$PROJECT:compile .",
    "docker:build-runtime": "export PROJECT=$(jq -r .name package.json) && export VERSION=$(jq -r .version package.json) && docker buildx build --target runtime-stage --build-arg BUILDKIT_INLINE_CACHE=1 -t infernokun/$PROJECT:$VERSION -t infernokun/${npm_package_name}:latest .",
    "docker:push": "export PROJECT=$(jq -r .name package.json) && export VERSION=$(jq -r .version package.json) && docker push infernokun/$PROJECT:$VERSION && docker push infernokun/$PROJECT:latest"
  },
  "private": true,
  "pnpm": {
    "overrides": {
      "node-fetch": "^3.3.2",
      "less": "^4.2.0"
    },
    "onlyBuiltDependencies": ["esbuild", "nx"]
  },
  "dependencies": {
    "@angular/animations": "^21.2.8",
    "@angular/cdk": "21.2.6",
    "@angular/common": "^21.2.8",
    "@angular/compiler": "^21.2.8",
    "@angular/core": "^21.2.8",
    "@angular/forms": "^21.2.8",
    "@angular/material": "21.2.6",
    "@angular/platform-browser": "^21.2.8",
    "@angular/platform-browser-dynamic": "^21.2.8",
    "@angular/router": "^21.2.8",
    "@ngrx/store": "21.1.0",
    "ag-grid-angular": "^35.2.1",
    "ag-grid-community": "^35.2.1",
    "apexcharts": "^5.10.5",
    "js-yaml": "^4.1.1",
    "jwt-decode": "4.0.0",
    "lodash-es": "^4.18.1",
    "luxon": "^3.7.2",
    "material-icons": "1.13.14",
    "ng-apexcharts": "^2.3.0",
    "ngx-device-detector": "^11.0.0",
    "ngx-papaparse": "^8.0.0",
    "ngx-skeleton-loader": "^12.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/core": "^21.2.7",
    "@angular-devkit/schematics": "^21.2.7",
    "@angular/build": "^21.2.7",
    "@angular/cli": "~21.2.7",
    "@angular/compiler-cli": "^21.2.8",
    "@module-federation/enhanced": "^0.18.0",
    "@nx/angular": "21.5.2",
    "@nx/workspace": "21.5.2",
    "@schematics/angular": "^21.2.7",
    "@types/jasmine": "~5.1.15",
    "@types/js-yaml": "^4.0.9",
    "@types/luxon": "^3.7.1",
    "autoprefixer": "^10.4.27",
    "jasmine-core": "~5.2.0",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.1",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "nx": "21.5.2",
    "sass": "^1.87.0",
    "typescript": "~5.9.3"
  }
}
